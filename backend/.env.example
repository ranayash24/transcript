# Database (auto-configured by docker-compose)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/vsi

# Redis / Celery (auto-configured by docker-compose)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MinIO — free, self-hosted, runs in Docker (no account needed)
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=video-scene-intelligence

# Qdrant — free, self-hosted, runs in Docker (no account needed)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ✅ ONLY KEY YOU NEED: Google Gemini (free tier — 1,500 req/day)
# Get it FREE at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Whisper — runs locally, no API key needed
WHISPER_MODEL=base

# Pipeline settings
FRAME_INTERVAL_SECONDS=5
SCENE_CHANGE_THRESHOLD=0.4
SEGMENT_WINDOW_SECONDS=15
MAX_VIDEO_SIZE_MB=500
SIGNED_URL_EXPIRY_HOURS=6

# Security
API_SECRET_KEY=change-me-in-production
